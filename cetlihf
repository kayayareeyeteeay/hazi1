#include <iostream>
#include <string>
#include <vector>
#include "graphics.hpp"

using namespace genv;
using namespace std;

const int szel = 800;
const int mag = 600;

struct Cetli {
private:
    int _x, _y, _size_x, _size_y;
    int _dx, _dy;
    int _szam;

public:
    bool _kijelolve;

    Cetli(int x, int y, int sx, int sy):
    _x(x),
    _y(y),
    _size_x(sx),
    _size_y(sy),
    _kijelolve(false),
    _szam(0)
    {
        // Biztosítjuk, hogy már létrehozáskor se lógjon ki
        if (_x < 0) _x = 0;
        if (_y < 0) _y = 0;
        if (_x > szel - _size_x) _x = szel - _size_x;
        if (_y > mag - _size_y) _y = mag - _size_y;
    }

    void rajzol() {
        // Keret (háttér)
        gout << move_to(_x, _y);
        if (_kijelolve) {
            gout << color(230, 160, 50); // Kijelölt keret (sötétebb narancs)
        } else {
            gout << color(220, 200, 100); // Sima keret (sötétebb sárga)
        }
        gout << box(_size_x, _size_y);

        // Belső rész (maga a cetli)
        gout << move_to(_x + 3, _y + 3);
        if (_kijelolve) {
            gout << color(255, 200, 100); // Kijelölt belső (világos narancs)
        } else {
            gout << color(255, 255, 180); // Sima belső (pasztell sárga)
        }
        gout << box(_size_x - 6, _size_y - 6);

        // Szám kirajzolása a cetli közepére
        string szoveg = to_string(_szam);
        int szoveg_szelesseg = gout.twidth(szoveg);

        gout << color(40, 40, 40); // Sötétszürke szöveg
        gout << move_to(_x + _size_x/2 - szoveg_szelesseg/2, _y + _size_y/2 - gout.cascent()/2);
        gout << text(szoveg);
    }

    bool folotte_van_a_kurzor(int egerx, int egery) {
        return egerx >= _x && egerx <= _size_x + _x && egery >= _y && egery <= _y +_size_y;
    }

    void kijelol() { _kijelolve = true; }
    void visszavon() { _kijelolve = false; }

    void mozgatas(int egerx, int egery) {
        _x = egerx + _dx;
        _y = egery + _dy;

        // Határellenőrzés: nem engedjük kimenni az ablakból
        if (_x < 0) _x = 0;
        if (_y < 0) _y = 0;
        if (_x > szel - _size_x) _x = szel - _size_x;
        if (_y > mag - _size_y) _y = mag - _size_y;
    }

    void megragad(int egerx, int egery) { _dx = _x - egerx; _dy = _y - egery; }
    void novel_szam(int ertek) { _szam += ertek; }
};

int main()
{
    vector<Cetli*> v;
    gout.open(szel, mag);
    gout << font("LiberationSans-Regular.ttf", 20);

    v.push_back(new Cetli(szel/2 - 40, mag/2 - 30, 80, 60));

    event ev;
    Cetli* aktualis_kijelolt = nullptr;

    while(gin >> ev)
    {
        if (ev.type == ev_mouse) {

            if (ev.button == btn_left) {
                bool talalt = false;
                for (int i = v.size() - 1; i >= 0; i--) {
                    if (v[i]->folotte_van_a_kurzor(ev.pos_x, ev.pos_y)) {
                        for (Cetli* c : v) c->visszavon();
                        v[i]->kijelol();
                        v[i]->megragad(ev.pos_x, ev.pos_y);
                        aktualis_kijelolt = v[i];
                        talalt = true;
                        break;
                    }
                }
                if (!talalt) {
                    for (Cetli* c : v) c->visszavon();
                    aktualis_kijelolt = nullptr;
                }
            }

            if (ev.button == btn_right) {
                v.push_back(new Cetli(ev.pos_x, ev.pos_y, 80, 60));
            }

            if (ev.button == btn_wheelup || ev.button == btn_wheeldown) {
                for (int i = v.size() - 1; i >= 0; i--) {
                    if (v[i]->folotte_van_a_kurzor(ev.pos_x, ev.pos_y) && v[i]->_kijelolve) {
                        if (ev.button == btn_wheelup) v[i]->novel_szam(1);
                        if (ev.button == btn_wheeldown) v[i]->novel_szam(-1);
                        break;
                    }
                }
            }

            if (ev.button == 0 && aktualis_kijelolt != nullptr) {
                aktualis_kijelolt->mozgatas(ev.pos_x, ev.pos_y);
            }

            if (ev.button == -btn_left) {
                aktualis_kijelolt = nullptr;
            }
        }

        // Egy szebb, sötétszürke háttér a fekete helyett, hogy a cetlik jól mutassanak rajta
        gout << color(40, 50, 60) << move_to(0, 0)  << box(szel, mag);
        for (Cetli *c : v) {
            c->rajzol();
        }
        gout << refresh;
    }

    for(Cetli* c : v) {
        delete c;
    }

    return 0;
}
